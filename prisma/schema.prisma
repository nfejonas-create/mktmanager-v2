generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [citext]
}

enum Platform {
  LINKEDIN
  FACEBOOK
}

enum ContentType {
  TEXT
  IMAGE
  TEXT_IMAGE
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  GEMINI
}

model SocialAccount {
  id           String    @id @default(cuid())
  userId       String
  platform     Platform
  accountName  String
  accountType  String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  externalId   String
  isDefault    Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  posts   Post[]
  metrics AccountMetric[]

  @@unique([userId, platform, accountName])
  @@index([userId, platform])
}

model Post {
  id              String        @id @default(cuid())
  userId          String
  socialAccountId String
  user            User          @relation(fields: [userId], references: [id])
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])

  content     String
  contentType ContentType
  mediaUrls   String[]

  status      PostStatus
  scheduledAt DateTime?
  publishedAt DateTime?
  externalId  String?
  externalUrl String?

  likes    Int @default(0)
  comments Int @default(0)
  shares   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([socialAccountId, status])
  @@index([scheduledAt, status])
}

model User {
  id           String          @id @default(cuid())
  email        Unsupported("citext") @unique
  passwordHash String
  name         String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  socialAccounts SocialAccount[]
  posts          Post[]
  automationConfig AutomationConfig?
}

model AutomationConfig {
  id                String     @id @default(cuid())
  userId            String     @unique
  active            Boolean    @default(false)
  cronExpression    String     @default("0 9 * * *")
  timezone          String     @default("America/Sao_Paulo")
  promptTemplate    String
  aiProvider        AIProvider
  aiApiKeyEncrypted String
  platforms         String[]
  autoPublish       Boolean    @default(true)
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model AccountMetric {
  id              String        @id @default(cuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])

  date        DateTime
  followers   Int   @default(0)
  impressions Int   @default(0)
  engagement  Float @default(0)

  @@unique([socialAccountId, date])
}
